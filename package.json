{
  "name": "better-in-brief-remotion",
  "version": "1.0.0",
  "private": true,
  "description": "Termux-first Remotion system for Better in Brief",
  "license": "UNLICENSED",
  "scripts": {
    "studio": "remotion studio app/remotion/src/index.ts",
